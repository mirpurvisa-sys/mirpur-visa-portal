generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Use your Supabase Postgres connection strings in DATABASE_URL and DIRECT_URL.
// Run this after adding the Supabase database URLs:
// npx prisma db pull
// npx prisma generate
